[doc Test if beamtools is able to produce a SDK without opengl components]

[include ../support/luxinc/utils.luxinc]
[include ../support/luxinc/kas.luxinc]

[global beamtools_cfg="base.yml:release.yml:qemuarm64.yml:erlang-maint-28.yml:elixir-1.18.yml:beamtools.yml:beamtools_x86_64.yml:beamtools_no_opengl.yml"]

[shell cmd]
    [invoke kas-prepare-env "../../"]

    [invoke kas-shell $beamtools_cfg]

    !bitbake beamtools-tarball
    [invoke wait-build-ok]

    !exit
    [invoke ok]
